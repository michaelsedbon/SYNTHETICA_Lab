    signal gpio27 ~ pin 12
    signal gpio14 ~ pin 13
    signal gpio12 ~ pin 14
    signal gpio13 ~ pin 16
    signal gpio15 ~ pin 23
    signal gpio2 ~ pin 24
    signal gpio0 ~ pin 25
    signal gpio4 ~ pin 26
    signal gpio16 ~ pin 27
    signal gpio17 ~ pin 28
    signal gpio5 ~ pin 29
    signal gpio18 ~ pin 30
    signal gpio19 ~ pin 31
    signal gpio21 ~ pin 33
