# ============================================================
# Power Supply Module
# USB 5V → DVDD 3.3V + AVDD 3.3V + ±5V for stimulation
# ============================================================

from "parts/Walsin_Tech_Corp_0805F106Z100CT/Walsin_Tech_Corp_0805F106Z100CT.ato" import Walsin_Tech_Corp_0805F106Z100CT_package
from "parts/Samsung_Electro_Mechanics_CL10A475KO8NNNC/Samsung_Electro_Mechanics_CL10A475KO8NNNC.ato" import Samsung_Electro_Mechanics_CL10A475KO8NNNC_package
from "parts/Advanced_Monolithic_Systems_AMS1117_3_3/Advanced_Monolithic_Systems_AMS1117_3_3.ato" import Advanced_Monolithic_Systems_AMS1117_3_3_package
from "parts/Texas_Instruments_TLV75733PDBVR/Texas_Instruments_TLV75733PDBVR.ato" import Texas_Instruments_TLV75733PDBVR_package
from "parts/Texas_Instruments_TPS65131RGER/Texas_Instruments_TPS65131RGER.ato" import Texas_Instruments_TPS65131RGER_package

module PowerSupply:
    signal vin
    signal gnd
    signal dvdd
    signal dgnd
    signal avdd
    signal agnd
    signal vpos
    signal vneg

    # ── Digital 3.3V LDO (AMS1117-3.3) ───────────
    # AMS1117 pins: GND=1, VOUT=2, VIN=3
    ldo_dig = new Advanced_Monolithic_Systems_AMS1117_3_3_package
    c_dig_in = new Walsin_Tech_Corp_0805F106Z100CT_package
    c_dig_out = new Walsin_Tech_Corp_0805F106Z100CT_package

    vin ~ ldo_dig.VIN
    vin ~ c_dig_in.p1
    gnd ~ ldo_dig.GND
    gnd ~ c_dig_in.p2
    gnd ~ c_dig_out.p2
    dvdd ~ ldo_dig.VOUT
    dvdd ~ c_dig_out.p1
    dgnd ~ gnd

    # ── Analog 3.3V LDO (TLV75733, low noise) ────
    # TLV75733 pins: IN=1, GND=2, EN=3, OUT=5
    ldo_ana = new Texas_Instruments_TLV75733PDBVR_package
    c_ana_in = new Samsung_Electro_Mechanics_CL10A475KO8NNNC_package
    c_ana_out = new Samsung_Electro_Mechanics_CL10A475KO8NNNC_package

    vin ~ ldo_ana.IN
    vin ~ c_ana_in.p1
    ldo_ana.EN ~ vin
    gnd ~ ldo_ana.GND
    gnd ~ c_ana_in.p2
    gnd ~ c_ana_out.p2
    avdd ~ ldo_ana.OUT
    avdd ~ c_ana_out.p1
    agnd ~ gnd

    # ── Bipolar ±5V DC-DC (TPS65131) ─────────────
    # TPS65131 key pins: VIN=1, ENP=8, VPOS(FBP=22), VNEG(FBN=16), AGND=19
    dcdc = new Texas_Instruments_TPS65131RGER_package
    c_dcdc_in = new Walsin_Tech_Corp_0805F106Z100CT_package
    c_dcdc_pos = new Walsin_Tech_Corp_0805F106Z100CT_package
    c_dcdc_neg = new Walsin_Tech_Corp_0805F106Z100CT_package

    dvdd ~ dcdc.VIN
    dvdd ~ c_dcdc_in.p1
    dcdc.ENP ~ dvdd
    gnd ~ dcdc.AGND
    gnd ~ c_dcdc_in.p2
    gnd ~ c_dcdc_pos.p2
    gnd ~ c_dcdc_neg.p2
    vpos ~ dcdc.FBP
    vpos ~ c_dcdc_pos.p1
    vneg ~ dcdc.FBN
    vneg ~ c_dcdc_neg.p1
