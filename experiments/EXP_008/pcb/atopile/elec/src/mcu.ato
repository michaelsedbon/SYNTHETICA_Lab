# ============================================================
# MCU Module — ESP32-S3-WROOM-1-N16R8
# ============================================================

from "parts/Samsung_Electro_Mechanics_CL05B104KO5NNNC/Samsung_Electro_Mechanics_CL05B104KO5NNNC.ato" import Samsung_Electro_Mechanics_CL05B104KO5NNNC_package
from "parts/Walsin_Tech_Corp_0805F106Z100CT/Walsin_Tech_Corp_0805F106Z100CT.ato" import Walsin_Tech_Corp_0805F106Z100CT_package
from "parts/Samsung_Electro_Mechanics_CL10A105KB8NNNC/Samsung_Electro_Mechanics_CL10A105KB8NNNC.ato" import Samsung_Electro_Mechanics_CL10A105KB8NNNC_package
from "parts/UNI_ROYAL_0402WGF1002TCE/UNI_ROYAL_0402WGF1002TCE.ato" import UNI_ROYAL_0402WGF1002TCE_package
from "parts/YAGEO_RC0402FR_071KL/YAGEO_RC0402FR_071KL.ato" import YAGEO_RC0402FR_071KL_package
from "parts/Espressif_Systems_ESP32_S3_WROOM_1_N16R8/Espressif_Systems_ESP32_S3_WROOM_1_N16R8.ato" import Espressif_Systems_ESP32_S3_WROOM_1_N16R8_package
from "parts/Everlight_Elec_19_217_GHC_YR1S2_3T/Everlight_Elec_19_217_GHC_YR1S2_3T.ato" import Everlight_Elec_19_217_GHC_YR1S2_3T_package
from "parts/Everlight_Elec_19_217_BHC_ZL1M2RY_3T/Everlight_Elec_19_217_BHC_ZL1M2RY_3T.ato" import Everlight_Elec_19_217_BHC_ZL1M2RY_3T_package

module MCU_Module:
    signal dvdd
    signal dgnd
    signal spi1_sclk
    signal spi1_mosi
    signal spi1_miso
    signal spi1_cs0
    signal gpio_drdy
    signal gpio_start
    signal gpio_reset
    signal spi2_sclk
    signal spi2_mosi
    signal spi2_cs0
    signal usb_dp
    signal usb_dm
    signal swdio
    signal swclk

    # ESP32-S3 pins: EN=3, GND=1/40/41, IO0-IO48
    mcu = new Espressif_Systems_ESP32_S3_WROOM_1_N16R8_package
    dvdd ~ mcu.IO2
    dgnd ~ mcu.GND

    # Enable RC
    r_en = new UNI_ROYAL_0402WGF1002TCE_package
    c_en = new Samsung_Electro_Mechanics_CL10A105KB8NNNC_package
    dvdd ~ r_en.p1
    r_en.p2 ~ mcu.EN
    mcu.EN ~ c_en.p1
    dgnd ~ c_en.p2

    # Decoupling
    c_vdd1 = new Samsung_Electro_Mechanics_CL05B104KO5NNNC_package
    dvdd ~ c_vdd1.p1
    dgnd ~ c_vdd1.p2

    c_vdd2 = new Walsin_Tech_Corp_0805F106Z100CT_package
    dvdd ~ c_vdd2.p1
    dgnd ~ c_vdd2.p2

    # SPI1 → ADS1299 (GPIO12=IO12, GPIO13=IO13, GPIO11=IO11, GPIO10=IO10)
    spi1_sclk ~ mcu.IO12
    spi1_mosi ~ mcu.IO13
    spi1_miso ~ mcu.IO11
    spi1_cs0 ~ mcu.IO10
    gpio_drdy ~ mcu.IO4
    gpio_start ~ mcu.IO5
    gpio_reset ~ mcu.IO6

    # SPI2 → DAC8564 (GPIO35=IO35, GPIO36=IO36, GPIO37=IO37)
    spi2_sclk ~ mcu.IO35
    spi2_mosi ~ mcu.IO36
    spi2_cs0 ~ mcu.IO37

    # USB (GPIO19=IO19, GPIO20=IO20)
    usb_dp ~ mcu.IO20
    usb_dm ~ mcu.IO19

    # Debug (GPIO41=IO41, GPIO42=IO42)
    swdio ~ mcu.IO41
    swclk ~ mcu.IO42

    # LEDs — Green(A=anode, C=cathode), Blue(A=anode, C=cathode)
    led_pwr = new Everlight_Elec_19_217_GHC_YR1S2_3T_package
    r_led_pwr = new YAGEO_RC0402FR_071KL_package
    dvdd ~ r_led_pwr.p1
    r_led_pwr.p2 ~ led_pwr.A
    led_pwr.C ~ dgnd

    led_act = new Everlight_Elec_19_217_BHC_ZL1M2RY_3T_package
    r_led_act = new YAGEO_RC0402FR_071KL_package
    mcu.IO8 ~ r_led_act.p1
    r_led_act.p2 ~ led_act.A
    led_act.C ~ dgnd
