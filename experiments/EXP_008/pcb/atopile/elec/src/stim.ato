# ============================================================
# Stimulation Circuit — 4ch DAC + Howland Current Pump
# 0–200 µA programmable constant-current source
# ============================================================

from "parts/Samsung_Electro_Mechanics_CL05B104KO5NNNC/Samsung_Electro_Mechanics_CL05B104KO5NNNC.ato" import Samsung_Electro_Mechanics_CL05B104KO5NNNC_package
from "parts/Walsin_Tech_Corp_0805F106Z100CT/Walsin_Tech_Corp_0805F106Z100CT.ato" import Walsin_Tech_Corp_0805F106Z100CT_package
from "parts/UNI_ROYAL_0402WGF1002TCE/UNI_ROYAL_0402WGF1002TCE.ato" import UNI_ROYAL_0402WGF1002TCE_package
from "parts/YAGEO_RC0402FR_071KL/YAGEO_RC0402FR_071KL.ato" import YAGEO_RC0402FR_071KL_package
from "parts/Texas_Instruments_DAC8564IAPWR/Texas_Instruments_DAC8564IAPWR.ato" import Texas_Instruments_DAC8564IAPWR_package
from "parts/Texas_Instruments_OPA4188AIPWR/Texas_Instruments_OPA4188AIPWR.ato" import Texas_Instruments_OPA4188AIPWR_package

module StimulationCircuit:
    signal vpos
    signal vneg
    signal gnd
    signal sclk
    signal din
    signal sync
    signal out1
    signal out2
    signal out3
    signal out4

    # ── DAC8564 (C2680186) ────────────────────────
    # Signals: AVDD, GND, VOUTA-D, SCLK, DIN, nSYNC, LDAC,
    #          VREFH_VREFOUT, VREFL, nENABLE, A0, A1, IOVDD
    dac = new Texas_Instruments_DAC8564IAPWR_package
    vpos ~ dac.AVDD
    vpos ~ dac.IOVDD
    vpos ~ dac.VREFH_VREFOUT
    gnd ~ dac.GND
    gnd ~ dac.VREFL
    gnd ~ dac.A0
    gnd ~ dac.A1
    gnd ~ dac.LDAC
    sclk ~ dac.SCLK
    din ~ dac.DIN
    sync ~ dac.nSYNC
    vpos ~ dac.nENABLE

    c_dac = new Samsung_Electro_Mechanics_CL05B104KO5NNNC_package
    vpos ~ c_dac.p1
    gnd ~ c_dac.p2

    c_dac_bulk = new Walsin_Tech_Corp_0805F106Z100CT_package
    vpos ~ c_dac_bulk.p1
    gnd ~ c_dac_bulk.p2

    # ── OPA4188 (C118204) ─────────────────────────
    # Signals: VSpos(V+), VSneg(V-), OUTA-D, INA_P/N, INB_P/N, INC_P/N, IND_P/N
    opamp = new Texas_Instruments_OPA4188AIPWR_package
    vpos ~ opamp.VSpos
    vneg ~ opamp.VSneg

    c_op_vcc = new Samsung_Electro_Mechanics_CL05B104KO5NNNC_package
    vpos ~ c_op_vcc.p1
    gnd ~ c_op_vcc.p2

    c_op_vee = new Samsung_Electro_Mechanics_CL05B104KO5NNNC_package
    vneg ~ c_op_vee.p1
    gnd ~ c_op_vee.p2

    # ── Howland Pump Ch1 ──────────────────────────
    rf1 = new UNI_ROYAL_0402WGF1002TCE_package
    ri1 = new UNI_ROYAL_0402WGF1002TCE_package
    rs1 = new YAGEO_RC0402FR_071KL_package
    dac.VOUTA ~ ri1.p1
    ri1.p2 ~ opamp.INA_P
    opamp.INA_N ~ rf1.p1
    opamp.OUTA ~ rf1.p2
    opamp.OUTA ~ rs1.p1
    rs1.p2 ~ out1

    # ── Howland Pump Ch2 ──────────────────────────
    rf2 = new UNI_ROYAL_0402WGF1002TCE_package
    ri2 = new UNI_ROYAL_0402WGF1002TCE_package
    rs2 = new YAGEO_RC0402FR_071KL_package
    dac.VOUTB ~ ri2.p1
    ri2.p2 ~ opamp.INB_P
    opamp.INB_N ~ rf2.p1
    opamp.OUTB ~ rf2.p2
    opamp.OUTB ~ rs2.p1
    rs2.p2 ~ out2

    # ── Howland Pump Ch3 ──────────────────────────
    rf3 = new UNI_ROYAL_0402WGF1002TCE_package
    ri3 = new UNI_ROYAL_0402WGF1002TCE_package
    rs3 = new YAGEO_RC0402FR_071KL_package
    dac.VOUTC ~ ri3.p1
    ri3.p2 ~ opamp.INC_P
    opamp.INC_N ~ rf3.p1
    opamp.OUTC ~ rf3.p2
    opamp.OUTC ~ rs3.p1
    rs3.p2 ~ out3

    # ── Howland Pump Ch4 ──────────────────────────
    rf4 = new UNI_ROYAL_0402WGF1002TCE_package
    ri4 = new UNI_ROYAL_0402WGF1002TCE_package
    rs4 = new YAGEO_RC0402FR_071KL_package
    dac.VOUTD ~ ri4.p1
    ri4.p2 ~ opamp.IND_P
    opamp.IND_N ~ rf4.p1
    opamp.OUTD ~ rf4.p2
    opamp.OUTD ~ rs4.p1
    rs4.p2 ~ out4
